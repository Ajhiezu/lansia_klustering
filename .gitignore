# ══════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg
dist/
build/

# ══════════════════════════════════════════════════════════════
# Virtual Environment
# ══════════════════════════════════════════════════════════════
.venv/
venv/
env/
ENV/

# ══════════════════════════════════════════════════════════════
# Environment Variables (berisi secret key & database URI)
# ══════════════════════════════════════════════════════════════
.env

# ══════════════════════════════════════════════════════════════
# IDE / Editor
# ══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ══════════════════════════════════════════════════════════════
# Logs
# ══════════════════════════════════════════════════════════════
logs/
*.log

# ══════════════════════════════════════════════════════════════
# Data Upload & Output (file user, bukan source code)
# ══════════════════════════════════════════════════════════════
uploads/*.xlsx
uploads/*.xls
uploads/*.csv
input/*.xlsx
input/*.xls
input/*.csv
csv/*.csv
outputs/

# ══════════════════════════════════════════════════════════════
# Visualisasi hasil (dihasilkan saat runtime)
# ══════════════════════════════════════════════════════════════
visualisasi/

# ══════════════════════════════════════════════════════════════
# Scratch / Test scripts
# ══════════════════════════════════════════════════════════════
scratch/

# ══════════════════════════════════════════════════════════════
# Database
# ══════════════════════════════════════════════════════════════
*.db
*.sqlite3

# ══════════════════════════════════════════════════════════════
# Alembic migration cache
# ══════════════════════════════════════════════════════════════
migrations/__pycache__/
migrations/versions/__pycache__/

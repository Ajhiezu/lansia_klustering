# ══════════════════════════════════════════════════════════════
# Konfigurasi Environment - Sistem Clustering Lansia
# ══════════════════════════════════════════════════════════════
# Salin file ini menjadi .env lalu sesuaikan nilainya:
#   copy .env.example .env
# ══════════════════════════════════════════════════════════════

# Secret key Flask (ganti dengan string acak)
FLASK_SECRET_KEY=lansia-clustering-secret-key-2026

# Koneksi database MySQL
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?charset=utf8mb4
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:@localhost:3306/puskesmas_tempeh?charset=utf8mb4
